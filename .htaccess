# Apache (cPanel / shared hosting). Remove if you only deploy to Netlify/Vercel/Cloudflare.

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  <FilesMatch "\.(css|js|svg)$">
    Header set Cache-Control "max-age=86400, public"
  </FilesMatch>
  <FilesMatch "\.(jpe?g|png|webp|gif|ico)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
</IfModule>

# If the site lives in a subfolder, use e.g. ErrorDocument 404 /subfolder/404.html
ErrorDocument 404 /404.html
