# Copy to .env.local for Next.js + API local dev (`npm run dev`).
# Production: set in Vercel → Project → Environment Variables.

# --- Public (browser + server) — required for /admin login & RSC
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only — waitlist API (POST /api/subscribe) + optional scripts
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# --- Waitlist email notifications (optional but recommended)
# New signups can be forwarded to info@primerisedrinks.com with signup source details.
WAITLIST_NOTIFY_TO=info@primerisedrinks.com
# Use the same address as SMTP_USER unless your provider allows a verified alias.
WAITLIST_NOTIFY_FROM=info@primerisedrinks.com
# Optional: Reply-To on confirmation emails to subscribers (defaults to WAITLIST_NOTIFY_TO)
# WAITLIST_SUBSCRIBER_REPLY_TO=info@primerisedrinks.com
# Optional: dedicated account-signup welcome email sender settings
# ACCOUNT_WELCOME_FROM=info@primerisedrinks.com
# ACCOUNT_WELCOME_REPLY_TO=no-reply@primerisedrinks.com
SMTP_HOST=smtp.your-mail-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# --- One-time backfill (Vercel-only): resend missed waitlist confirmations
# Set this in Vercel env vars and call the endpoint with:
# Authorization: Bearer <WAITLIST_BACKFILL_SECRET>
WAITLIST_BACKFILL_SECRET=change-me

# --- Stripe (checkout) — get keys from https://dashboard.stripe.com/apikeys
# Webhook: Dashboard → Developers → Webhooks → Add endpoint → URL: https://YOUR_DOMAIN/api/webhooks/stripe
#          Events: checkout.session.completed — copy signing secret to STRIPE_WEBHOOK_SECRET
# Set to "true" only when Stripe keys are fully configured.
NEXT_PUBLIC_STRIPE_ENABLED=false
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Canonical site URL for Stripe redirects (production)
NEXT_PUBLIC_SITE_URL=https://primerisedrinks.com

# WhatsApp floating button (digits only, country code included, e.g. US +1 281-555-1234 → 12815551234)
# Match public/whatsapp-config.js for static HTML pages.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# --- Optional
# PRIME_RISE_GA_ID=
